{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Team",
  "version": "0.1.0",
  "identifier": "com.hermes.team",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:17331",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hermes Team",
        "width": 1320,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
